@using Microsoft.AspNetCore.SignalR.Client
@inject IJSRuntime JS
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

@if (currentRoom != null)
{
    <div class="d-flex flex-column justify-center">
        @if (!currentRoom.Observing)
        {
            <Cards OnCardClick="OnCardVote" CurrentEstimate="@currentEstimate"></Cards>
        }

        <div class="d-flex justify-center mt-5">
            <div>
                <MudPaper Width="300px">
                    <MudTable Items="voters" Hover="true" Breakpoint="Breakpoint.Sm">
                        <HeaderContent>
                            <MudTh><MudText Typo="Typo.h6">Name</MudText></MudTh>
                            <MudTh><MudText Typo="Typo.h6">Estimate</MudText></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><MudText Typo="Typo.body1">@context.Name</MudText></MudTd>
                            <MudTd>
                                @showEstimate(context)
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
                @if (observers.Any())
                {
                    <MudPaper Class="mt-3 pa-3">
                        <MudText Typo="Typo.h6">Observers: @observersCSV</MudText>
                    </MudPaper>
                }
            </div>

            <div class="ml-5">
                <MudCard>
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h5" Align="Align.Center">Estimate Controls</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardActions>
                        <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center">
                            <MudSwitch Value="autoReveal" ValueChanged="OnAutoRevealChanged" Label="Auto-reveal" Color="Color.Primary" Disabled="showEstimates" />
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="SendResetEstimates">Reset Estimates</MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="SendRevealEstimates">Show Estimates</MudButton>
                        </MudStack>
                    </MudCardActions>
                </MudCard>
            </div>
        </div>

        @if (showEstimates && voteStats is { } stats)
        {
            <div class="d-flex justify-center mt-3">
                <MudPaper Class="pa-4" Style="min-width:300px">
                    @if (stats.IsConsensus)
                    {
                        <MudText Typo="Typo.h5" Align="Align.Center" Color="Color.Success">Consensus! Everyone voted @stats.ConsensusValue</MudText>
                    }
                    else
                    {
                        <MudStack Spacing="1">
                            @if (stats.Min != null)
                            {
                                <MudText><b>Min:</b> @stats.Min — @string.Join(", ", stats.MinVoters)</MudText>
                                <MudText><b>Max:</b> @stats.Max — @string.Join(", ", stats.MaxVoters)</MudText>
                                <MudText><b>Average (nearest card):</b> @stats.AverageCard</MudText>
                                <MudText><b>Mode:</b> @stats.ModeCard — @string.Join(", ", stats.ModeVoters)</MudText>
                            }
                            @if (stats.QuestionMarkCount > 0)
                            {
                                <MudText><b>Voted ?:</b> @stats.QuestionMarkCount</MudText>
                            }
                        </MudStack>
                    }
                </MudPaper>
            </div>
        }
    </div>
}

@code {
    // ── Fields & Parameters ───────────────────────────────────────────────────

    private List<RoomUser> users = [];
    private Room? currentRoom = null;
    private bool showEstimates = false;
    private string? currentEstimate = null;
    private bool autoReveal = false;

    [Parameter, EditorRequired]
    public required HubConnection HubConnection { get; set; }

    [Parameter, EditorRequired]
    public required string Name { get; set; }

    // ── Computed Properties ───────────────────────────────────────────────────

    private List<RoomUser> voters => users.Where(x => !x.Observing).OrderBy(x => x.Name).ToList();
    private IEnumerable<string> observers => users.Where(x => x.Observing).OrderBy(x => x.Name).Select(x => x.Name).ToArray();
    private string observersCSV => string.Join(", ", observers).Trim();

    private VoteStats? voteStats => showEstimates ? VoteStats.Calculate(voters) : null;

    // ── Render Helpers ────────────────────────────────────────────────────────

    RenderFragment showEstimate(RoomUser user) => (showEstimates, user.Estimate) switch
    {
        (_, null)  => @<MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary" Class="ma-0" Style="visibility: hidden"></MudChip>,
        (true, _)  => @<MudChip T="string" Variant="Variant.Outlined" Color="Color.Primary" Class="ma-0">
                          <span style="min-width: 1.2em; text-align: center">@user.Estimate</span>
                      </MudChip>,
        (false, _) => @<MudChip T="string" Variant="Variant.Outlined" Color="Color.Default" Class="ma-0">
                          <span style="min-width: 1.2em; text-align: center"></span>
                      </MudChip>
    };

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        autoReveal = await LocalStorage.GetItemAsync<bool>(StorageKeys.AutoReveal);
        await WireUpHub();
    }

    // ── Public Methods ────────────────────────────────────────────────────────

    public async Task JoinRoom(Room room)
    {
        currentRoom = room;
        users.Clear();
        showEstimates = false;
        await HubConnection.SendAsync(HubMessages.JoinRoom, currentRoom.Id, room.Observing);

        var storedEstimate = await JS.InvokeAsync<string?>("sessionStorage.getItem", StorageKeys.CurrentEstimate);
        if (!string.IsNullOrEmpty(storedEstimate))
        {
            currentEstimate = storedEstimate;
            await HubConnection.SendAsync(HubMessages.SubmitEstimate, currentRoom.Id, storedEstimate);
        }
    }

    public async Task ExitRoom()
    {
        await HubConnection.SendAsync(HubMessages.ExitRoom, currentRoom!.Id);
        await JS.InvokeVoidAsync("sessionStorage.removeItem", StorageKeys.CurrentEstimate);
        currentRoom = null;
    }

    // ── Private Event Handlers ────────────────────────────────────────────────

    private async Task OnAutoRevealChanged(bool value)
    {
        autoReveal = value;
        await LocalStorage.SetItemAsync(StorageKeys.AutoReveal, value);
    }

    private async Task SendResetEstimates()
    {
        await HubConnection.SendAsync(HubMessages.ResetEstimates, currentRoom!.Id);
    }

    private async Task SendRevealEstimates()
    {
        await HubConnection.SendAsync(HubMessages.RevealEstimates, currentRoom!.Id);
    }

    private async Task WireUpHub()
    {
        HubConnection.On<string, string, string, bool>(HubMessages.JoinRoom, OnJoinRoom);
        HubConnection.On<string, string, bool, string?, bool>(HubMessages.AnnounceAlreadyInTheRoom, OnAnnounceAlreadyInTheRoom);
        HubConnection.On<string, string>(HubMessages.SubmitEstimate, OnSubmitEstimate);
        HubConnection.On<string>(HubMessages.RemoveFromRoom, RemoveFromRoom);
        HubConnection.On(HubMessages.RevealEstimates, OnRevealEstimates);
        HubConnection.On(HubMessages.ResetEstimates, OnResetEstimates);
    }

    private async Task OnJoinRoom(string userId, string connectionId, string userName, bool observing)
    {
        var existingUser = users.SingleOrDefault(x => x.Id == userId);

        if (existingUser != null)
        {
            existingUser.Observing = observing;
        }
        else
        {
            users.Add(new RoomUser(userId, userName, observing));
        }

        await HubConnection.SendAsync(HubMessages.AnnounceAlreadyInTheRoom, connectionId, currentRoom!.Observing, currentEstimate, showEstimates);
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnAnnounceAlreadyInTheRoom(string userId, string userName, bool observing, string? estimate, bool revealed)
    {
        var existingUser = users.SingleOrDefault(x => x.Id == userId);
        if (existingUser == null)
        {
            existingUser = new RoomUser(userId, userName, observing);
            users.Add(existingUser);
        }
        else
        {
            existingUser.Observing = observing;
        }

        if (estimate != null)
            existingUser.Estimate = estimate;

        if (revealed)
            showEstimates = true;

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnSubmitEstimate(string userId, string estimate)
    {
        if (showEstimates)
            return;

        var user = users.SingleOrDefault(x => x.Id == userId);

        if (user is null)
            return;

        user.Estimate = estimate;

        if (autoReveal && AllVotesIn())
            await HubConnection.SendAsync(HubMessages.RevealEstimates, currentRoom!.Id);

        await InvokeAsync(StateHasChanged);
    }

    private bool AllVotesIn() =>
        voters.Count > 0 && voters.All(u => u.Estimate != null);

    private async Task OnRevealEstimates()
    {
        showEstimates = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnResetEstimates()
    {
        showEstimates = false;
        currentEstimate = null;
        await JS.InvokeVoidAsync("sessionStorage.removeItem", StorageKeys.CurrentEstimate);
        users.ForEach(x => x.Estimate = null);
        await InvokeAsync(StateHasChanged);
    }

    private async Task RemoveFromRoom(string userId)
    {
        var user = users.SingleOrDefault(x => x.Id == userId);

        if (user is null)
            return;

        users.Remove(user);

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnCardVote(string estimate)
    {
        if (currentRoom == null || showEstimates)
            return;

        currentEstimate = estimate;
        await JS.InvokeVoidAsync("sessionStorage.setItem", StorageKeys.CurrentEstimate, estimate);
        await HubConnection.SendAsync(HubMessages.SubmitEstimate, currentRoom.Id, estimate);
    }
}
