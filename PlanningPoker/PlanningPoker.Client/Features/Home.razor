@page "/"
@using Microsoft.AspNetCore.SignalR.Client

<PageTitle>Planning Poker</PageTitle>

<div class="d-flex justify-center">
    <Login OnLoginSuccess="OnLogin"></Login>
</div>

@if (currentUser != null)
{
    <div class="d-flex flex-column justify-center">
        <div class="mt-5">
            <RoomPicker OnRoomSelection="OnJoinRoom" OnRoomExit="OnExitRoom"></RoomPicker>
        </div>
        <div class="mt-5">
            <PokerRoom @ref="pokerRoom" Name="name" HubConnection="hubConnection"></PokerRoom>
        </div>
    </div>

    <div style="position: fixed; bottom: 12px; right: 12px; opacity: 0.5; z-index: 1000; pointer-events: none; display: flex; align-items: center; gap: 6px;">
        <span style="width: 10px; height: 10px; border-radius: 50%; background-color: @connectionColor; display: inline-block;"></span>
        <MudText Typo="Typo.caption">@connectionText</MudText>
    </div>
}

@code{
    private HubConnection? hubConnection;
    private AppUser? currentUser = null;
    private Room? currentRoom = null;
    private PokerRoom pokerRoom;
    private string connectionColor = "#3dcb6c";
    private string connectionText = "Connected";

    private void OnLogin(LoginResult result)
    {
        hubConnection = result.HubConnection;
        currentUser = result.User;

        hubConnection.Reconnected += async _ =>
        {
            connectionColor = "#3dcb6c";
            connectionText = "Connected";
            await hubConnection.InvokeAsync(HubMessages.Login, currentUser.Id, currentUser.Name);
            if (currentRoom != null)
                await pokerRoom.JoinRoom(currentRoom);
            await InvokeAsync(StateHasChanged);
        };

        hubConnection.Reconnecting += async _ =>
        {
            connectionColor = "#ffb545";
            connectionText = "Reconnecting...";
            await InvokeAsync(StateHasChanged);
        };

        hubConnection.Closed += async _ =>
        {
            connectionColor = "#ff3f5f";
            connectionText = "Disconnected";
            await InvokeAsync(StateHasChanged);
        };
    }

    private void OnPickRoom(Room room)
    {
        currentRoom = room;
    }

    private async Task OnJoinRoom(Room room)
    {
        currentRoom = room;
        await pokerRoom.JoinRoom(currentRoom);
    }

    private async Task OnExitRoom()
    {
        currentRoom = null;
        await pokerRoom.ExitRoom();
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}
